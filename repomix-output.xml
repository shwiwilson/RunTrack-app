import 'package:flutter/foundation.dart';
import 'package:run_track_app/src/core/data/mock_run_track_repository.dart';

class ClubHubViewModel extends ChangeNotifier {
  factory ClubHubViewModel({
    required MockRunTrackRepository repository,
    required String clubId,
  }) {
    return ClubHubViewModel._(repository, clubId);
  }

  ClubHubViewModel._(this._repository, this._clubId);

  final MockRunTrackRepository _repository;
  final String _clubId;

  ClubHubState get state {
    return ClubHubState(
      sessions: [
        for (final row in _repository.fetchClubSessions(_clubId))
          ClubSessionItem.fromJson(row),
      ],
      stagedItems: [
        for (final row in _repository.fetchNewsletterStaging(_clubId))
          NewsletterStagingItem.fromJson(row),
      ],
    );
  }
}

@immutable
class ClubHubState {
  const ClubHubState({required this.sessions, required this.stagedItems});

  final List<ClubSessionItem> sessions;
  final List<NewsletterStagingItem> stagedItems;
}

@immutable
class ClubSessionItem {
  const ClubSessionItem({
    required this.title,
    required this.description,
    required this.date,
    required this.time,
    required this.location,
    required this.spondUrl,
    required this.rsvpInitials,
  });

  final String title;
  final String description;
  final String date;
  final String time;
  final String location;
  final String spondUrl;
  final List<String> rsvpInitials;

  factory ClubSessionItem.fromJson(Map<String, dynamic> json) {
    return ClubSessionItem(
      title: json['title'] as String,
      description: json['description'] as String,
      date: json['date'] as String,
      time: json['time'] as String,
      location: json['location'] as String,
      spondUrl: json['spond_url'] as String,
      rsvpInitials: [
        for (final initial in json['rsvp_initials'] as List<dynamic>)
          initial as String,
      ],
    );
  }
}

@immutable
class NewsletterStagingItem {
  const NewsletterStagingItem({
    required this.source,
    required this.status,
    required this.date,
    required this.time,
    required this.location,
    required this.description,
  });

  final String source;
  final String status;
  final String date;
  final String time;
  final String location;
  final String description;

  factory NewsletterStagingItem.fromJson(Map<String, dynamic> json) {
    final extractedJson = json['extracted_json'] as Map<String, dynamic>;

    return NewsletterStagingItem(
      source: json['source'] as String,
      status: json['status'] as String,
      date: extractedJson['date'] as String,
      time: extractedJson['time'] as String,
      location: extractedJson['location'] as String,
      description: extractedJson['description'] as String,
    );
  }
