  RunTrackViewModel._(this._repository, this._clubId);

  final MockRunTrackRepository _repository;
  final String _clubId;

  RunTrackFeedState get state {
    final activities = _repository.fetchActivities(_clubId);

    return RunTrackFeedState(
      syncSummary: 'Synced Strava, Garmin and COROS mock webhooks on open',
      activities: [
        for (final activity in activities) ActivityFeedItem.fromJson(activity),
      ],
    );
