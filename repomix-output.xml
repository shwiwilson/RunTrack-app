import 'package:flutter/foundation.dart';
import 'package:run_track_app/src/core/data/mock_run_track_repository.dart';

class AchievementsViewModel extends ChangeNotifier {
  factory AchievementsViewModel({
    required MockRunTrackRepository repository,
    required String clubId,
  }) {
    return AchievementsViewModel._(repository, clubId);
  }

  AchievementsViewModel._(this._repository, this._clubId);

  final MockRunTrackRepository _repository;
  final String _clubId;

  AchievementsState get state {
    final row = _repository.fetchAchievements(_clubId);
    final efficiency = row['efficiency_factor'] as Map<String, dynamic>;

    return AchievementsState(
      efficiencyLabel: efficiency['label'] as String,
      efficiencyValue: efficiency['value'] as String,
      efficiencyTrend: efficiency['trend'] as String,
      raceResults: [
        for (final result in row['race_results'] as List<dynamic>)
          RaceResultItem.fromJson(result as Map<String, dynamic>),
      ],
      challengeFlags: [
        for (final flag in row['challenge_flags'] as List<dynamic>)
          ChallengeFlag.fromJson(flag as Map<String, dynamic>),
      ],
      mapTiles: [
        for (final tile in row['map_bingo_tiles'] as List<dynamic>)
          MapBingoTileState.fromJson(tile as Map<String, dynamic>),
      ],
    );
  }
}

@immutable
class AchievementsState {
  const AchievementsState({
    required this.efficiencyLabel,
    required this.efficiencyValue,
    required this.efficiencyTrend,
    required this.raceResults,
    required this.challengeFlags,
    required this.mapTiles,
  });

  final String efficiencyLabel;
  final String efficiencyValue;
  final String efficiencyTrend;
  final List<RaceResultItem> raceResults;
  final List<ChallengeFlag> challengeFlags;
  final List<MapBingoTileState> mapTiles;
}

@immutable
class RaceResultItem {
  const RaceResultItem({
    required this.event,
    required this.time,
    required this.result,
  });

  final String event;
  final String time;
  final String result;

  factory RaceResultItem.fromJson(Map<String, dynamic> json) {
    return RaceResultItem(
      event: json['event'] as String,
      time: json['time'] as String,
      result: json['result'] as String,
    );
  }
}

@immutable
class ChallengeFlag {
  const ChallengeFlag({required this.label, required this.value});

  final String label;
  final String value;

  factory ChallengeFlag.fromJson(Map<String, dynamic> json) {
    return ChallengeFlag(
      label: json['label'] as String,
      value: json['value'] as String,
    );
  }
}

@immutable
class MapBingoTileState {
  const MapBingoTileState({required this.label, required this.visited});

  final String label;
  final bool visited;

  factory MapBingoTileState.fromJson(Map<String, dynamic> json) {
    return MapBingoTileState(
      label: json['label'] as String,
      visited: json['visited'] as bool,
    );
  }
}
