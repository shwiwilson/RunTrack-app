import 'package:run_track_app/features/profile/presentation/view_models/you_view_model.dart';
import 'package:run_track_app/features/profile/presentation/views/you_tab.dart';
import 'package:run_track_app/src/core/data/mock_run_track_repository.dart';
import 'package:run_track_app/src/core/theme/club_theme_config.dart';

final ValueNotifier<bool> useMocksNotifier = ValueNotifier<bool>(true);

void main() {
  const repository = MockRunTrackRepository();

  runApp(RunTrackApp(viewModel: RunTrackAppViewModel(repository: repository)));
}

@immutable
class RunTrackAppState {
  const RunTrackAppState({
    required this.clubName,
    required this.clubShortName,
    required this.activeClubTheme,
    required this.selectedTabIndex,
  });

  final String clubName;
  final String clubShortName;
  final ClubThemeConfig activeClubTheme;
  final int selectedTabIndex;
}

class RunTrackAppViewModel extends ChangeNotifier {
  factory RunTrackAppViewModel({required MockRunTrackRepository repository}) {
    return RunTrackAppViewModel._(repository);
  }

  RunTrackAppViewModel._(this._repository) {
    final clubProfile = _repository.fetchDefaultClubProfile();
    _clubId = clubProfile['id'] as String;
    _clubName = clubProfile['name'] as String;
    _clubShortName = clubProfile['shortName'] as String;
    _clubTheme = ClubThemeConfig.fromJson(
      clubProfile['theme_json'] as Map<String, dynamic>,
    );
    youViewModel = YouViewModel(repository: _repository, clubId: _clubId);
    runTrackViewModel = RunTrackViewModel(
      repository: _repository,
      clubId: _clubId,
    );
    clubHubViewModel = ClubHubViewModel(
      repository: _repository,
      clubId: _clubId,
    );
    achievementsViewModel = AchievementsViewModel(
      repository: _repository,
      clubId: _clubId,
    );
  }

  final MockRunTrackRepository _repository;
  late final String _clubId;
  late final String _clubName;
  late final String _clubShortName;
  late final ClubThemeConfig _clubTheme;
  int _selectedTabIndex = 0;

  late final YouViewModel youViewModel;
  late final RunTrackViewModel runTrackViewModel;
  late final ClubHubViewModel clubHubViewModel;
  late final AchievementsViewModel achievementsViewModel;

  RunTrackAppState get state {
    return RunTrackAppState(
      clubName: _clubName,
      clubShortName: _clubShortName,
      activeClubTheme: _clubTheme,
      selectedTabIndex: _selectedTabIndex,
    );
  }

  void selectTab(int index) {
    _selectedTabIndex = index;
    notifyListeners();
  }
}

class RunTrackApp extends StatelessWidget {
  const RunTrackApp({required this.viewModel, super.key});

  final RunTrackAppViewModel viewModel;

  @override
  Widget build(BuildContext context) {
    return ListenableBuilder(
      listenable: viewModel,
      builder: (context, _) {
        final appState = viewModel.state;

        return MaterialApp(
          title: appState.clubName,
          debugShowCheckedModeBanner: false,
          theme: appState.activeClubTheme.toThemeData(),
          home: RunTrackShell(viewModel: viewModel, appState: appState),
        );
      },
    );
  }
}

class RunTrackShell extends StatelessWidget {
  const RunTrackShell({
    required this.viewModel,
    required this.appState,
    super.key,
  });

  final RunTrackAppViewModel viewModel;
  final RunTrackAppState appState;

  List<_ShellTab> get _tabs {
    return [
      _ShellTab(
        title: 'You',
        icon: Icons.person_outline,
        activeIcon: Icons.person,
        view: YouTabScreen(viewModel: viewModel.youViewModel),
      ),
      _ShellTab(
        title: 'RunTrack',
        icon: Icons.directions_run_outlined,
        activeIcon: Icons.directions_run,
        view: RunTrackView(viewModel: viewModel.runTrackViewModel),
      ),
      _ShellTab(
        title: 'Club',
        icon: Icons.groups_outlined,
        activeIcon: Icons.groups,
        view: ClubHubView(viewModel: viewModel.clubHubViewModel),
      ),
      _ShellTab(
        title: 'Achievements',
        icon: Icons.emoji_events_outlined,
        activeIcon: Icons.emoji_events,
        view: AchievementsView(viewModel: viewModel.achievementsViewModel),
      ),
    ];
  }

  @override
  Widget build(BuildContext context) {
    final tokens = ClubThemeTokens.of(context);
    final tabs = _tabs;

    return Scaffold(
      appBar: AppBar(
        title: Row(
          children: [
            Expanded(child: Text(tabs[appState.selectedTabIndex].title)),
            Flexible(
              child: Text(
                appState.clubShortName,
                textAlign: TextAlign.right,
                style: Theme.of(context).textTheme.labelLarge,
              ),
            ),
          ],
        ),
      ),
      body: IndexedStack(
        index: appState.selectedTabIndex,
        children: [for (final tab in tabs) tab.view],
      ),
      bottomNavigationBar: DecoratedBox(
        decoration: BoxDecoration(
          border: Border(top: BorderSide(color: tokens.strokeColor)),
        ),
        child: BottomNavigationBar(
          currentIndex: appState.selectedTabIndex,
          onTap: viewModel.selectTab,
          items: [
            for (final tab in tabs)
              BottomNavigationBarItem(
                icon: Icon(tab.icon),
                activeIcon: Icon(tab.activeIcon),
                label: tab.title,
              ),
          ],
        ),
      ),
    );
  }
}

@immutable
class _ShellTab {
  const _ShellTab({
    required this.title,
    required this.icon,
    required this.activeIcon,
    required this.view,
  });

  final String title;
  final IconData icon;
  final IconData activeIcon;
  final Widget view;
}
