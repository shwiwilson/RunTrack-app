import 'package:flutter/foundation.dart';
import 'package:run_track_app/src/core/data/mock_run_track_repository.dart';

class YouViewModel extends ChangeNotifier {
  factory YouViewModel({
    required MockRunTrackRepository repository,
    required String clubId,
  }) {
    return YouViewModel._(repository, clubId);
  }

  YouViewModel._(this._repository, this._clubId);

  final MockRunTrackRepository _repository;
  final String _clubId;

  YouTabState get state {
    final row = _repository.fetchReadiness(_clubId);

    return YouTabState(
      athleteName: row['athlete_name'] as String,
      readinessScore: '${row['readiness_score']}',
      readinessLabel: row['readiness_label'] as String,
      coachInsight: row['coach_insight'] as String,
      metrics: [
        for (final metric in row['metrics'] as List<dynamic>)
          BiometricMetric.fromJson(metric as Map<String, dynamic>),
      ],
      benchmarks: [
        for (final benchmark in row['benchmarks'] as List<dynamic>)
          BenchmarkMetric.fromJson(benchmark as Map<String, dynamic>),
      ],
    );
  }
}

@immutable
class YouTabState {
  const YouTabState({
    required this.athleteName,
    required this.readinessScore,
    required this.readinessLabel,
    required this.coachInsight,
    required this.metrics,
    required this.benchmarks,
  });

  final String athleteName;
  final String readinessScore;
  final String readinessLabel;
  final String coachInsight;
  final List<BiometricMetric> metrics;
  final List<BenchmarkMetric> benchmarks;
}

@immutable
class BiometricMetric {
  const BiometricMetric({
    required this.label,
    required this.value,
    required this.trend,
    required this.status,
  });

  final String label;
  final String value;
  final String trend;
  final String status;

  factory BiometricMetric.fromJson(Map<String, dynamic> json) {
    return BiometricMetric(
      label: json['label'] as String,
      value: json['value'] as String,
      trend: json['trend'] as String,
      status: json['status'] as String,
    );
  }
}

@immutable
class BenchmarkMetric {
  const BenchmarkMetric({required this.label, required this.value});

  final String label;
  final String value;

  factory BenchmarkMetric.fromJson(Map<String, dynamic> json) {
    return BenchmarkMetric(
      label: json['label'] as String,
      value: json['value'] as String,
    );
  }
}
</file>

