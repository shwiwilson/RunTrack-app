import 'package:run_track_app/src/core/mock_data/mock_supabase_db.dart';

class MockRunTrackRepository {
  const MockRunTrackRepository();

  Map<String, dynamic> fetchDefaultClubProfile() {
    return fetchClubProfile(defaultClubSlug);
  }

  Map<String, dynamic> fetchClubProfile(String clubSlug) {
    final clubs = mockSupabaseDb['club_profiles'] as List<dynamic>;

    return clubs.cast<Map<String, dynamic>>().firstWhere(
      (club) => club['slug'] == clubSlug,
    );
  }

  Map<String, dynamic> fetchReadiness(String clubId) {
    final rows = mockSupabaseDb['athlete_readiness'] as List<dynamic>;

    return rows.cast<Map<String, dynamic>>().firstWhere(
      (row) => row['club_id'] == clubId,
    );
  }

  List<Map<String, dynamic>> fetchActivities(String clubId) {
    final rows = mockSupabaseDb['activity_feed'] as List<dynamic>;

    return rows
        .cast<Map<String, dynamic>>()
        .where((row) => row['club_id'] == clubId)
        .toList(growable: false);
  }

  List<Map<String, dynamic>> fetchClubSessions(String clubId) {
    final rows = mockSupabaseDb['club_sessions'] as List<dynamic>;

    return rows
        .cast<Map<String, dynamic>>()
        .where((row) => row['club_id'] == clubId)
        .toList(growable: false);
  }

  List<Map<String, dynamic>> fetchNewsletterStaging(String clubId) {
    final rows = mockSupabaseDb['newsletter_staging'] as List<dynamic>;

    return rows
        .cast<Map<String, dynamic>>()
        .where((row) => row['club_id'] == clubId)
        .toList(growable: false);
  }

  Map<String, dynamic> fetchAchievements(String clubId) {
    final row = mockSupabaseDb['achievements'] as Map<String, dynamic>;

    if (row['club_id'] != clubId) {
      return const {};
    }

    return row;
  }
}
